    "typescript": "^5.4.5"
  },
  "engines": {
    "node": "20.17.x"
  },
  "packageManager": "pnpm@9.11.0",
  "lint-staged": {
    "*": [
      "prettier --write --ignore-unknown"
    ]
  }
